// ============================================================
// AI API Key Harvesting
// TacticCategory: CredentialAccess
// Source: DeviceFileEvents + DeviceProcessEvents
//
// Detects two signals:
//   1. Non-IDE processes reading known secrets files (.env,
//      secrets.json, api_keys.txt, etc.)
//   2. Process command lines containing AI API key patterns
//      (OpenAI sk-proj-, Anthropic sk-ant-, etc.)
//
// AI API keys have immediate financial value — attackers sell
// or use stolen keys for compute abuse, making this one of the
// highest-priority AI credential detections.
//
// FP Reduction:
//   - IDEs and editors excluded from file read signal (they
//     constantly scan .env files as part of normal operation)
//   - First-seen baselining suppresses a developer's own script
//     reading their own .env after the first hunt run
//   - Evidence normalization (config.json) redacts actual key
//     values before they land in the workbook
//
// Noise sources:
//   - dotenv library loading on process start (add known app
//     process names to known_env_readers if too noisy)
//
// Tuning:
//   hunt_window          — how recent the reported events must be
//   baseline_window      — total lookback including baseline period
//   prevalence_threshold — suppress patterns seen on > N devices
// ============================================================
let hunt_window          = 1d;
let baseline_window      = 3d;
let prevalence_threshold = 5;

// IDEs, editors, and runtime loaders that legitimately read .env files
let known_env_readers = dynamic([
    "Code.exe", "Cursor.exe", "windsurf.exe",
    "idea64.exe", "pycharm64.exe", "webstorm64.exe", "rider64.exe", "clion64.exe",
    "devenv.exe",
    "notepad.exe", "notepad++.exe", "sublime_text.exe", "atom.exe",
    "fleet.exe", "zed.exe"
]);

// System processes that should never be flagged regardless of file access
let system_processes = dynamic([
    "SearchIndexer.exe", "MsMpEng.exe", "SenseIR.exe",
    "svchost.exe", "lsass.exe", "System", "Registry"
]);

// --- Signal 1: Reads of known secrets files by non-IDE processes ---
let file_hits = materialize(
    DeviceFileEvents
    | where Timestamp > ago(baseline_window)
    | where ActionType in ("FileRead", "FileAccessed")
    | where FileName has_any (
        ".env", ".env.local", ".env.production", ".env.development", ".env.staging",
        "secrets.json", "credentials.json", "api_keys.json", "api_keys.txt",
        ".netrc", "serviceAccountKey.json", ".openai", ".anthropic"
    )
    | where InitiatingProcessFileName !in~ (known_env_readers)
    | where InitiatingProcessFileName !in~ (system_processes)
    | extend AccountName = InitiatingProcessAccountName
    | extend Evidence = strcat(
        "File: ",       FolderPath, "\\", FileName,
        " | ReadBy: ",  InitiatingProcessFileName,
        " | CmdLine: ", InitiatingProcessCommandLine,
        " | Parent: ",  InitiatingProcessParentFileName,
        " | Action: ",  ActionType
    )
    | project Timestamp, DeviceName, AccountName, Evidence
);

// --- Signal 2: Command lines referencing AI API key patterns ---
// Catches scripts that embed or echo key material directly.
// Key values are redacted by evidence_normalizations in config.json.
let cmdline_hits = materialize(
    DeviceProcessEvents
    | where Timestamp > ago(baseline_window)
    | where ProcessCommandLine has_any (
        "OPENAI_API_KEY", "ANTHROPIC_API_KEY", "GEMINI_API_KEY",
        "COHERE_API_KEY", "MISTRAL_API_KEY", "GROQ_API_KEY",
        "sk-proj-", "sk-ant-",
        "Bearer sk-", "x-api-key: sk-"
    )
    | where FileName !in~ (known_env_readers)
    | where FileName !in~ (system_processes)
    | extend AccountName = InitiatingProcessAccountName
    | extend Evidence = strcat(
        "Process: ",  FileName,
        " | CmdLine: ", ProcessCommandLine,
        " | Parent: ", InitiatingProcessFileName,
        " | Path: ",   FolderPath
    )
    | project Timestamp, DeviceName, AccountName, Evidence
);

let all_suspicious = materialize(
    union file_hits, cmdline_hits
    | extend DetectionType  = "AI API Key Read"
    | extend TacticCategory = "CredentialAccess"
    | project Timestamp, DeviceName, AccountName, DetectionType, TacticCategory, Evidence
);

let detections = all_suspicious | where Timestamp > ago(hunt_window);
let baseline   = all_suspicious
    | where Timestamp <= ago(hunt_window)
    | distinct DeviceName, Evidence;
let rare = detections
    | summarize DeviceCount = dcount(DeviceName) by Evidence
    | where DeviceCount <= prevalence_threshold
    | project Evidence;

detections
| join kind=inner   rare     on Evidence
| join kind=leftanti baseline on DeviceName, Evidence
| project Timestamp, DeviceName, AccountName, DetectionType, TacticCategory, Evidence
| sort by Timestamp desc
