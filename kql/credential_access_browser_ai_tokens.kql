// ============================================================
// Browser AI Token Theft
// TacticCategory: CredentialAccess
// Source: DeviceFileEvents
//
// AI provider API sessions are authenticated via browser cookies
// and session tokens stored in the browser profile directory.
// A stolen claude.ai session cookie or chatgpt.com auth token
// gives an attacker access to the victim's AI workspace —
// including custom GPTs, Claude projects, uploaded files, and
// potentially MCP-connected local tools (remote MCP).
//
// This query detects non-browser processes reading browser
// credential stores that contain AI provider authentication:
//   - Chrome/Edge "Login Data" SQLite DB (saved passwords)
//   - Chrome/Edge/Firefox "Cookies" DB (session cookies)
//   - Chrome/Edge Local Storage / Session Storage LevelDB dirs
//     (JWT tokens, auth state stored by AI web apps)
//
// Targeted credential stores per browser:
//   Chrome:  %LOCALAPPDATA%\Google\Chrome\User Data\Default\
//   Edge:    %LOCALAPPDATA%\Microsoft\Edge\User Data\Default\
//   Firefox: %APPDATA%\Mozilla\Firefox\Profiles\<profile>\
//   Brave:   %LOCALAPPDATA%\BraveSoftware\Brave-Browser\User Data\Default\
//
// Threat scenarios:
//   1. Infostealer harvesting AI session cookies alongside bank creds
//   2. Insider extracting AI session tokens to authenticate as a
//      colleague on a corporate AI platform
//   3. Malware staging browser creds before exfiltration to
//      attacker's AI-powered automation infrastructure
//
// FP Reduction:
//   - Browser processes themselves excluded
//   - Backup tools (Windows Backup, VSS, robocopy) excluded
//   - File indexers and AV excluded
//   - First-seen baselining suppresses profile sync tools
//
// Tuning:
//   hunt_window          — how recent the reported events must be
//   baseline_window      — total lookback including baseline period
//   prevalence_threshold — suppress patterns seen on > N devices
// ============================================================
let hunt_window          = 1d;
let baseline_window      = 3d;
let prevalence_threshold = 5;

// Browser processes legitimately accessing their own credential stores
let browser_processes = dynamic([
    "chrome.exe", "msedge.exe", "firefox.exe", "brave.exe",
    "opera.exe", "vivaldi.exe", "iexplore.exe"
]);

// Browser credential file names of interest
let cred_file_names = dynamic([
    "Login Data",
    "Login Data For Account",
    "Cookies",
    "Web Data"
]);

// Browser credential directory path fragments
let browser_profile_paths = dynamic([
    "\\Google\\Chrome\\User Data\\",
    "\\Microsoft\\Edge\\User Data\\",
    "\\BraveSoftware\\Brave-Browser\\User Data\\",
    "\\Mozilla\\Firefox\\Profiles\\",
    "\\Opera Software\\Opera Stable\\",
    "\\Vivaldi\\User Data\\"
]);

// LevelDB / Local Storage dirs where AI session tokens are persisted
let browser_storage_paths = dynamic([
    "\\Local Storage\\leveldb\\",
    "\\Session Storage\\",
    "\\IndexedDB\\"
]);

// Processes that legitimately read browser profiles (backup, sync, migration)
let excluded_readers = dynamic([
    "MsMpEng.exe", "SenseIR.exe", "SearchIndexer.exe",
    "OneDrive.exe", "googledrivesync.exe",
    "robocopy.exe", "xcopy.exe", "robocopy",
    "BackupEngine.exe", "wbengine.exe",
    "CSFalconService.exe", "CSFalconServiceHost.exe",
    "svchost.exe", "System", "Registry"
]);

let all_suspicious = materialize(
    DeviceFileEvents
    | where Timestamp > ago(baseline_window)
    | where ActionType in ("FileRead", "FileCreated", "FileCopied")
    | where
        // Credential database files
        (FileName in~ (cred_file_names)
         and FolderPath has_any (browser_profile_paths))
        // Session storage / LevelDB dirs where AI JWTs live
        or FolderPath has_any (browser_storage_paths)
    | where InitiatingProcessFileName !in~ (browser_processes)
    | where InitiatingProcessFileName !in~ (excluded_readers)
    | where InitiatingProcessAccountName !endswith "$"
    | extend AccountName = InitiatingProcessAccountName
    | extend Evidence = strcat(
        "CredFile: ",  FolderPath, "\\", FileName,
        " | Action: ", ActionType,
        " | Reader: ", InitiatingProcessFileName,
        " | RPath: ",  InitiatingProcessFolderPath,
        " | CmdLine: ", InitiatingProcessCommandLine,
        " | Parent: ", InitiatingProcessParentFileName
    )
    | project Timestamp, DeviceName, AccountName,
        DetectionType  = "Browser AI Token Theft",
        TacticCategory = "CredentialAccess",
        Evidence
);
// ---- FP Reduction -----------------------------------------------
let detections = all_suspicious | where Timestamp > ago(hunt_window);
let baseline   = all_suspicious
    | where Timestamp <= ago(hunt_window)
    | distinct DeviceName, Evidence;
let rare = detections
    | summarize DeviceCount = dcount(DeviceName) by Evidence
    | where DeviceCount <= prevalence_threshold
    | project Evidence;

detections
| join kind=inner   rare     on Evidence
| join kind=leftanti baseline on DeviceName, Evidence
| project Timestamp, DeviceName, AccountName, DetectionType, TacticCategory, Evidence
| sort by Timestamp desc
