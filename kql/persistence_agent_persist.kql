// ============================================================
// AI Agent Creating System Persistence Mechanism
// TacticCategory: Persistence
// Source: DeviceRegistryEvents + DeviceFileEvents
//
// AI agents should not need to create OS-level persistence.
// If an AI agent or a process it spawned writes a registry Run
// key, drops a scheduled task XML, or plants a startup folder
// item, this indicates either:
//   1. Prompt injection caused the agent to create persistence
//      on behalf of an attacker
//   2. A compromised agent framework or MCP server is installing
//      a traditional persistence mechanism alongside its AI work
//   3. Autonomous AI agent operating outside expected boundaries
//      (self-replication or "ensure I keep running" behavior)
//
// Two data sources:
//   A. DeviceRegistryEvents — Run/RunOnce key writes
//   B. DeviceFileEvents — scheduled task XML drops, startup LNKs
//
// FP Reduction:
//   - Legitimate software installers that coincidentally have an
//     AI process parent are suppressed by first-seen baselining
//   - Prevalence threshold suppresses org-wide admin tooling
//
// Tuning:
//   hunt_window          — how recent the reported events must be
//   baseline_window      — total lookback including baseline period
//   prevalence_threshold — suppress patterns seen on > N devices
// ============================================================
let hunt_window          = 1d;
let baseline_window      = 3d;
let prevalence_threshold = 5;

let ai_agent_processes = dynamic([
    "Claude.exe", "Cursor.exe", "windsurf.exe", "code.exe",
    "ollama.exe", "python.exe", "node.exe", "bash.exe", "cmd.exe", "powershell.exe"
]);

// Grand-parent must be an AI agent for shell children to count
let ai_agent_grandparents = dynamic([
    "Claude.exe", "Cursor.exe", "windsurf.exe", "code.exe",
    "ollama.exe", "python.exe"
]);

// --- Signal A: Registry Run key writes ---
let reg_persistence = materialize(
    DeviceRegistryEvents
    | where Timestamp > ago(baseline_window)
    | where ActionType in ("RegistryValueSet", "RegistryKeyCreated")
    | where RegistryKey has_any (
        "HKEY_CURRENT_USER\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",
        "HKEY_LOCAL_MACHINE\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",
        "HKEY_CURRENT_USER\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce",
        "HKEY_LOCAL_MACHINE\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce",
        "HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon"
    )
    // Direct AI agent writer, OR shell child of AI agent
    | where InitiatingProcessFileName in~ (ai_agent_processes)
        and (InitiatingProcessFileName in~ (ai_agent_grandparents)
             or InitiatingProcessParentFileName in~ (ai_agent_grandparents))
    | extend AccountName = InitiatingProcessAccountName
    | extend Evidence = strcat(
        "RegKey: ",    RegistryKey,
        " | Value: ",  RegistryValueName,
        " | Data: ",   RegistryValueData,
        " | Writer: ", InitiatingProcessFileName,
        " | Parent: ", InitiatingProcessParentFileName
    )
    | project Timestamp, DeviceName, AccountName,
        DetectionType  = "Agent Persistence Mechanism",
        TacticCategory = "Persistence",
        Evidence
);

// --- Signal B: Scheduled task XML / startup folder drops ---
let file_persistence = materialize(
    DeviceFileEvents
    | where Timestamp > ago(baseline_window)
    | where ActionType in ("FileCreated", "FileModified")
    | where
        // Scheduled task XML in Windows Tasks directory
        (FolderPath has "\\Windows\\System32\\Tasks" and FileName endswith ".xml")
        // Startup folder scripts / shortcuts
        or (FolderPath has_any (
                "\\Microsoft\\Windows\\Start Menu\\Programs\\Startup",
                "\\AppData\\Roaming\\Microsoft\\Windows\\Start Menu\\Programs\\Startup"
            )
            and FileName has_any (".lnk", ".bat", ".cmd", ".vbs", ".ps1", ".exe"))
    | where InitiatingProcessFileName in~ (ai_agent_processes)
        and (InitiatingProcessFileName in~ (ai_agent_grandparents)
             or InitiatingProcessParentFileName in~ (ai_agent_grandparents))
    | extend AccountName = InitiatingProcessAccountName
    | extend Evidence = strcat(
        "PersistFile: ", FolderPath, "\\", FileName,
        " | Action: ",   ActionType,
        " | Writer: ",   InitiatingProcessFileName,
        " | CmdLine: ",  InitiatingProcessCommandLine,
        " | Parent: ",   InitiatingProcessParentFileName
    )
    | project Timestamp, DeviceName, AccountName,
        DetectionType  = "Agent Persistence Mechanism",
        TacticCategory = "Persistence",
        Evidence
);

let all_suspicious = materialize(union reg_persistence, file_persistence);
// ---- FP Reduction -----------------------------------------------
let detections = all_suspicious | where Timestamp > ago(hunt_window);
let baseline   = all_suspicious
    | where Timestamp <= ago(hunt_window)
    | distinct DeviceName, Evidence;
let rare = detections
    | summarize DeviceCount = dcount(DeviceName) by Evidence
    | where DeviceCount <= prevalence_threshold
    | project Evidence;

detections
| join kind=inner   rare     on Evidence
| join kind=leftanti baseline on DeviceName, Evidence
| project Timestamp, DeviceName, AccountName, DetectionType, TacticCategory, Evidence
| sort by Timestamp desc
