{
  "tactic_weights": {
    "CredentialAccess":   10,
    "LateralMovement":     8,
    "DefenseEvasion":      8,
    "CommandAndControl":   9,
    "Impact":             10,
    "Execution":           5,
    "Persistence":         7,
    "Discovery":           3,
    "Exfiltration":        9,
    "Collection":          6
  },
  "tactic_transitions": {
    "pairs": [
      {"tactics": ["Execution",        "CredentialAccess"],  "multiplier": 1.3},
      {"tactics": ["Execution",        "Persistence"],       "multiplier": 1.3},
      {"tactics": ["Execution",        "DefenseEvasion"],    "multiplier": 1.2},
      {"tactics": ["Execution",        "CommandAndControl"], "multiplier": 1.3},
      {"tactics": ["CredentialAccess", "Exfiltration"],      "multiplier": 1.5},
      {"tactics": ["CredentialAccess", "LateralMovement"],   "multiplier": 1.4},
      {"tactics": ["Persistence",      "CommandAndControl"], "multiplier": 1.4},
      {"tactics": ["Persistence",      "Exfiltration"],      "multiplier": 1.4},
      {"tactics": ["Execution",        "Collection"],        "multiplier": 1.2},
      {"tactics": ["Collection",       "Exfiltration"],      "multiplier": 1.5},
      {"tactics": ["LateralMovement",  "Exfiltration"],      "multiplier": 1.5},
      {"tactics": ["DefenseEvasion",   "Persistence"],       "multiplier": 1.3}
    ],
    "max_multiplier": 2.5
  },

  "detection_type_multipliers": {
    "AI Data Exfiltration":            1.8,
    "AI API Key Read":                 1.5,
    "Jupyter Shell Execution":         1.3,
    "AI Agent Memory Write":           1.2,
    "Shadow AI Tooling":               1.0,
    "MCP Config Tampered":             2.5,
    "MCP Unexpected Network":          2.0,
    "MCP Server Installed":            1.5,
    "MCP Server Execution":            1.5,
    "Unexpected Agent Process Spawn":  2.0,
    "Agent Persistence Mechanism":     2.0,
    "Agent IPC Abuse":                 1.8,
    "AI Model Weight Exfiltration":    2.5,
    "Browser AI Token Theft":          2.5,
    "RAG Unusual Access":              1.5
  },
  "detection_families": {
    "AI Data Exfiltration":           "AI",
    "AI API Key Read":                "AI",
    "Shadow AI Tooling":              "AI",
    "Jupyter Shell Execution":        "AI",
    "AI Agent Memory Write":          "AI",
    "MCP Server Installed":           "AI",
    "MCP Server Execution":           "AI",
    "MCP Config Tampered":            "AI",
    "MCP Unexpected Network":         "AI",
    "Unexpected Agent Process Spawn": "AI",
    "Agent Persistence Mechanism":    "AI",
    "Agent IPC Abuse":                "AI",
    "AI Model Weight Exfiltration":   "AI",
    "Browser AI Token Theft":         "AI",
    "RAG Unusual Access":             "AI"
  },
  "episode_window_hours": 4,
  "prevalence_suppression_threshold": 10,
  "prevalence_boost_threshold": 3,
  "prevalence_suppression_multiplier": 0.2,
  "prevalence_boost_multiplier": 1.5,
  "alert_severity_weights": {
    "High": 10,
    "Medium": 6,
    "Low": 3,
    "Informational": 1
  },
  "mde_alert_frequency_boost_threshold": 2,
  "mde_alert_frequency_boost_multiplier": 1.5,
  "max_scenes_per_pattern_per_device": 3,
  "use_evidence_clustering": false,
  "evidence_clustering_sim_threshold": 0.5,
  "evidence_normalizations": [
    {"pattern": "(?i)(c:\\\\users\\\\)[^\\\\]+(\\\\)", "replacement": "\\1<user>\\2"},
    {"pattern": "(?i)(\\\\temp\\\\)[^\\\\]+\\.cmdline", "replacement": "\\1<random>.cmdline"},
    {"pattern": "(?i)(RemoteUrl: https?://[^?#]+)[?#][^|]*", "replacement": "\\1<params>"},
    {"pattern": "(?i)(sk-(?:proj-|ant-|or-v1-)?)[A-Za-z0-9_\\-]{10,}", "replacement": "\\1<redacted>"}
  ],

  "lolbin_trust_tiers": {
    "baseline_common": ["bash.exe", "python.exe", "python3.exe", "node.exe", "perl.exe", "ruby.exe", "sh.exe", "wsl.exe"],
    "contextual":      ["wscript.exe", "cscript.exe", "rundll32.exe", "regsvr32.exe", "msiexec.exe", "msbuild.exe", "csc.exe", "installutil.exe"],
    "high_signal":     ["certutil.exe", "mshta.exe", "msdt.exe", "cmstp.exe", "odbcconf.exe", "forfiles.exe", "pcalua.exe", "presentationhost.exe"]
  },
  "lolbin_tier_base_multipliers": {
    "baseline_common": 0.3,
    "contextual":      1.0,
    "high_signal":     1.8,
    "unknown":         1.0
  },
  "developer_parent_processes": [
    "code.exe", "cursor.exe", "windsurf.exe", "claude.exe",
    "windowsterminal.exe", "wt.exe", "node.exe", "idea64.exe", "pycharm64.exe"
  ],
  "dev_context_discount": 0.25,
  "cmdline_risk_patterns": {
    "high_risk":   ["base64 -d", "base64 -D", "-EncodedCommand", "IEX", "Invoke-Expression", "certutil -decode", "certutil -urlcache", "DownloadString", "DownloadFile", "mshta http"],
    "medium_risk": ["whoami", "net user", "net group", "ipconfig /all", "systeminfo", "nltest", "net view", "curl.*| bash", "wget.*| sh", "nmap", "masscan"],
    "low_risk":    ["git ", "npm ", "pip ", "pytest", "cargo ", "make ", "cmake ", "mvn ", "gradle ", "yarn ", "pnpm ", "python setup.py"]
  },
  "cmdline_risk_multipliers": {
    "high_risk":   2.0,
    "medium_risk": 1.3,
    "low_risk":    0.4,
    "neutral":     1.0
  },
  "behavior_families": {
    "AI Agent Memory Write":          "Persistence",
    "AI Data Exfiltration":           "DataExfiltration",
    "AI API Key Read":                "CredentialDump",
    "Jupyter Shell Execution":        "ShellExecution",
    "Shadow AI Tooling":              "ShellExecution",
    "MCP Server Installed":           "MCPAbuse",
    "MCP Server Execution":           "MCPAbuse",
    "MCP Config Tampered":            "MCPAbuse",
    "MCP Unexpected Network":         "MCPAbuse",
    "Unexpected Agent Process Spawn": "AgentAttack",
    "Agent Persistence Mechanism":    "AgentAttack",
    "Agent IPC Abuse":                "AgentAttack",
    "AI Model Weight Exfiltration":   "ModelTheft",
    "Browser AI Token Theft":         "TokenTheft",
    "RAG Unusual Access":             "DataAccess"
  },
  "episode_family_cap": 3,
  "episode_family_cap_multipliers": {
    "ShellExecution":    0.3,
    "Persistence":       0.7,
    "CredentialDump":    1.0,
    "DataExfiltration":  1.0,
    "MCPAbuse":          1.0,
    "AgentAttack":       1.0,
    "ModelTheft":        1.0,
    "TokenTheft":        1.0,
    "DataAccess":        1.0
  },
  "corroboration_bonus": {
    "min_families_for_bonus":      2,
    "bonus_per_additional_family": 1.4,
    "max_bonus_multiplier":        5.0
  },
  "season_diminishing_returns": {
    "diminishing_log_base":     2.0,
    "same_family_decay_after":  1,
    "same_family_decay_factor": 0.5
  },

  "attack_chain_hygiene": {
    "exclude_machine_accounts": true,
    "excluded_accounts": [
      "system", "network service", "local service", "anonymous logon",
      "iusr", "iwam", "aspnet"
    ],
    "min_device_season_score": 0,
    "min_unique_tactics": 0,
    "fan_out_threshold": 3
  },

  "adaptive_behavior": {
    "variation_cluster_min_size": 3,
    "variation_score_bonus":      1.15
  },

  "workflow_classification": {
    "ai_path_patterns":  ["/.claude/", "\\.claude\\"],
    "ai_process_names":  ["claude", "claude.exe", "claude-code"],
    "ai_parent_names":   ["claude.exe", "claude-code", "claude"],
    "ai_process_parent_pairs": [["bash", "bash"]],
    "priority_min_tactics_for_ai_dev": 2
  },

  "history": {
    "enabled":                        true,
    "store_path":                     "output/hunt_history.db",
    "minimum_runs_for_baseline":      3,
    "score_spike_multiplier":         2.5,
    "score_spike_min_mean":           1.0,
    "zscore_threshold":               2.0,
    "emerging_entity_score_threshold": 10.0,
    "emerging_entity_max_runs":       2,
    "tactic_expansion_threshold":     1,
    "max_runs_per_entity":            90
  }
}
